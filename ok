<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Cinefile</title>

<style>
body {
  margin: 0;
  background: #0a0a0a;
  color: #eaeaea;
  font-family: Arial, sans-serif;
}

/* NAV */
.nav {
  display: flex;
  justify-content: space-between;
  padding: 15px 25px;
  border-bottom: 1px solid #1f1f1f;
}

.logo {
  font-weight: bold;
  letter-spacing: 2px;
}

.nav a {
  color: #888;
  text-decoration: none;
  margin-left: 15px;
}

/* HERO */
.hero {
  padding: 40px 25px;
}

.hero h1 {
  font-size: 28px;
  margin-bottom: 10px;
}

.hero p {
  color: #777;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  padding: 25px;
}

/* CARD */
.card {
  background: #111;
  padding: 10px;
  transition: 0.3s;
}

.card:hover {
  transform: scale(1.03);
}

/* VIDEO */
iframe {
  width: 100%;
  height: 160px;
  border: none;
}

/* TEXT */
.title {
  font-size: 14px;
  margin-top: 8px;
}

.user {
  font-size: 12px;
  color: #666;
}

/* CREATE */
.create {
  padding: 25px;
  border-top: 1px solid #1f1f1f;
}

input {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
  background: #111;
  border: 1px solid #333;
  color: white;
}

button {
  margin-top: 10px;
  padding: 10px;
  background: #222;
  color: white;
  border: none;
  cursor: pointer;
}
</style>
</head>

<body>

<!-- NAV -->
<div class="nav">
  <div class="logo">CINEFILE</div>
  <div>
    <a href="#">explore</a>
    <a href="#">profile</a>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <h1>archiving digital emotion</h1>
  <p>not content. not trends. just fragments.</p>
</div>

<!-- VIDEO GRID -->
<div class="grid" id="videoGrid"></div>

<!-- CREATE -->
<div class="create">
  <h3>add a file</h3>
  <input id="videoURL" placeholder="paste youtube link">
  <input id="videoTitle" placeholder="title">
  <button onclick="addVideo()">archive</button>
</div>

<script>
// starter videos (seed content)
let videos = [
  {
    title: "midnight fragments",
    user: "@void",
    url: "https://www.youtube.com/embed/ScMzIvxBSi4"
  },
  {
    title: "i forgot summer",
    user: "@glassgirl",
    url: "https://www.youtube.com/embed/tgbNymZ7vqY"
  }
];

// render videos
function renderVideos() {
  const grid = document.getElementById("videoGrid");
  grid.innerHTML = "";

  videos.forEach(v => {
    const div = document.createElement("div");
    div.className = "card";

    div.innerHTML = `
      <iframe src="${v.url}" allowfullscreen></iframe>
      <div class="title">${v.title}</div>
      <div class="user">${v.user}</div>
    `;

    grid.appendChild(div);
  });
}

// convert youtube link → embed
function convertURL(url) {
  if (url.includes("watch?v=")) {
    return url.replace("watch?v=", "embed/");
  }
  return url;
}

// add video
function addVideo() {
  const urlInput = document.getElementById("videoURL").value;
  const titleInput = document.getElementById("videoTitle").value;

  const embed = convertURL(urlInput);

  videos.unshift({
    title: titleInput || "untitled fragment",
    user: "@you",
    url: embed
  });

  renderVideos();
}

// initial load
renderVideos();
</script>

</body>
</html>
